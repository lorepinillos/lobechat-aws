aws_region   = "eu-west-1"
aws_profile  = "esade"
project_name = "lobechat"
environment  = "dev"
owner        = "your.name"

# Lock SSH to your current public IP. Find with: curl -s https://checkip.amazonaws.com
allowed_ssh_cidr = "203.0.113.10/32"

# Paste the contents of your SSH public key (cat ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA... user@host"

instance_type        = "t3.xlarge"
root_volume_size_gb  = 60
