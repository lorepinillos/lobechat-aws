{
	admin off
}

# LobeChat — primary hostname
{$HOST_DOMAIN_LOBE} {
	reverse_proxy lobe-chat:3210 {
		header_up Host {host}
		header_up X-Forwarded-Proto https
		transport http {
			read_timeout 300s
			keepalive 300s
		}
	}
}

# Casdoor SSO — auth-prefixed hostname (own cert, own LE issuance)
{$HOST_DOMAIN_AUTH} {
	reverse_proxy casdoor:8000 {
		header_up Host {host}
		header_up X-Forwarded-Proto https
	}
}

# MinIO S3 API — s3-prefixed hostname (presigned URLs sign against this host)
{$HOST_DOMAIN_S3} {
	reverse_proxy minio:9000 {
		header_up Host {host}
	}
}

# Reject anything that does not match the expected hostnames.
:80 {
	respond "Misdirected Request" 421
}
